#!/bin/bash

export LD_LIBRARY_PATH="${_CONDA_BACKUP_LD_LIBRARY_PATH_RIOPLUS:-}"
unset _CONDA_BACKUP_LD_LIBRARY_PATH_RIOPLUS

if [ -n "${_CONDA_BACKUP_ROOTSYS_RIOPLUS:-}" ]; then
    export ROOTSYS="${_CONDA_BACKUP_ROOTSYS_RIOPLUS}"
    unset _CONDA_BACKUP_ROOTSYS_RIOPLUS
fi

# Remove modulemap files installed into this conda environment.
for _f in "${CONDA_PREFIX}/lib/"*.modulemap; do
    [ -f "$_f" ] && export CLING_MODULEMAP_FILES="${CLING_MODULEMAP_FILES//${_f}:/}"
done
unset _f
